SUPABASE_PUBLIC_URL=http://localhost:54321
SUPABASE_SITE_URL=http://localhost:3000

SUPABASE_API_PORT=54321
SUPABASE_DB_PORT=54322
SUPABASE_STUDIO_PORT=54323

# Optional overrides
GOTRUE_DISABLE_SIGNUP=false
GOTRUE_EXTERNAL_EMAIL_ENABLED=false
GOTRUE_MAILER_AUTOCONFIRM=true

STUDIO_ORGANIZATION_NAME=Local
STUDIO_PROJECT_NAME=test-allocation-planner

STORAGE_BUCKET=local
STORAGE_REGION=local
STORAGE_TENANT_ID=stub
STORAGE_FILE_SIZE_LIMIT=52428800

REALTIME_SECRET_KEY_BASE=realtime-secret-key-base-32-chars
REALTIME_ERLANG_COOKIE=realtime-erlang-cookie
SUPABASE_REALTIME_APP_NAME=supabase-realtime
SUPABASE_REALTIME_ERL_AFLAGS=-proto_dist inet_tcp
